# Mem0 Cloud (care memory)
MEM0_API_KEY=

# Groq (Whisper transcription + LLM response phrasing)
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Firebase Admin (Firestore for profiles + caregiver tokens)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Deep link base for generated caregiver URLs
CAREGIVER_LINK_BASE_URL=careloop://c
